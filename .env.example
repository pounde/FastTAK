###############################################################################
# FastTAK Environment Configuration
#
# First run:
#   ./setup.sh <takserver-docker-X.X.zip>
#   vim .env                # set FQDN, review passwords
#   ./start.sh              # or: docker compose up -d --build
###############################################################################

# =============================================================================
# User Settings — review and set these before starting
# =============================================================================

# Your domain name. Used for SSL certificates, subdomain routing, QR enrollment,
# and server cert generation. Must resolve to this host's public IP.
FQDN=tak.example.com

# Admin password for the 'webadmin' user. This account is used to log in to:
#   - TAK Server web admin at https://<FQDN>:8446
#   - TAK Portal (when PORTAL_AUTH_ENABLED=true, via Authentik SSO)
# Both authenticate against Authentik LDAP — same user, same password.
# DEFAULT VALUE — change for production.
TAK_WEBADMIN_PASSWORD=FastTAK-Admin-1!

# =============================================================================
# Version Pins — change to upgrade services
# =============================================================================

TAK_VERSION=5.6
AUTHENTIK_VERSION=2026.2.1
MEDIAMTX_VERSION=1.15.5
NODERED_VERSION=4.1
TAK_PORTAL_VERSION=1.2.53

# =============================================================================
# Subdomains (defaults shown — override if needed)
# =============================================================================

TAKSERVER_SUBDOMAIN=takserver
MEDIAMTX_SUBDOMAIN=stream
AUTHENTIK_SUBDOMAIN=auth
TAKPORTAL_SUBDOMAIN=portal
NODERED_SUBDOMAIN=nodered
MONITOR_SUBDOMAIN=monitor

# =============================================================================
# Internal Secrets — generated by setup.sh, used for container-to-container
# communication. Users do not interact with these directly.
# If not using setup.sh, generate with the noted commands.
# =============================================================================

# TAK database password (martiuser PostgreSQL role)
# Generate with:  openssl rand -hex 16
TAK_DB_PASSWORD=

# Authentik internal signing key
# Generate with:  openssl rand -hex 32
AUTHENTIK_SECRET_KEY=

# App database password (shared PostgreSQL for Authentik + Node-RED)
# Generate with:  openssl rand -hex 16
APP_DB_PASSWORD=

# Authentik bootstrap API token (LDAP setup, flow creation)
# Generate with:  openssl rand -hex 32
AUTHENTIK_API_TOKEN=

# LDAP bind password (TAK Server service account for Authentik LDAP)
# Generate with:  openssl rand -hex 16
LDAP_BIND_PASSWORD=

# Authentik admin UI password (akadmin user). The Authentik UI is not
# exposed by default — access requires a port forward (see docs).
# Only needed for advanced configuration (custom flows, branding, SMTP).
# DEFAULT VALUE — change for production.
AUTHENTIK_ADMIN_PASSWORD=FastTAK-Admin-1!

# =============================================================================
# Optional Settings
# =============================================================================

# Authentik admin email
#AUTHENTIK_ADMIN_EMAIL=admin@example.com

# LDAP base DN (default: DC=takldap)
#LDAP_BASE_DN=DC=takldap

# PostgreSQL connection URI — only set this if you are NOT using Docker Compose
# and need to connect to an external database. Leave unset for standard deployments.
# Format: postgresql://user:password@host:port/dbname
#TAK_DB_URL=postgresql://martiuser:mypassword@db-host:5432/cot

# SMTP relay for email notifications and password reset
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=noreply@example.com

# =============================================================================
# Monitor Settings (optional — enable for health alerts)
# =============================================================================

# Email alerts
#ALERT_EMAIL=ops@example.com

# SMS alerts (optional)
#SMS_PROVIDER=twilio   # "twilio" or "brevo"
#SMS_API_KEY=           # Twilio: "account_sid:auth_token" / Brevo: API key
#SMS_FROM=+15551234567
#SMS_TO=+15559876543    # Comma-separated

# ── User Management ─────────────────────────────────────────────
# Authentik (already used by bootstrap/portal, now also used by API)
# AUTHENTIK_URL=http://authentik-server:9000
# AUTHENTIK_API_TOKEN=  (set during setup)

# TAK Server API (mTLS)
TAK_SERVER_URL=https://tak-server:8443
TAK_API_CERT_PATH=/opt/tak/certs/files/svc_fasttakapi.p12
TAK_API_CERT_PASSWORD=atakatak

# User management settings
USERS_HIDDEN_PREFIXES=ak-,adm_,svc_,ma-
USER_EXPIRY_CHECK_INTERVAL=60
ENROLLMENT_TTL_MINUTES=15
TAK_ENROLLMENT_PORT=8446

# =============================================================================
# PostgreSQL Autovacuum Tuning (defaults tuned for TAK Server's CoT workload)
# =============================================================================
# These are applied automatically. Override to adjust, or set to PG defaults
# (0.2, 200, 64MB) to disable FastTAK tuning.

#PG_AUTOVACUUM_SCALE_FACTOR=0.05    # trigger at 5% dead rows (PG default: 0.2)
#PG_AUTOVACUUM_COST_LIMIT=1000      # 5x faster cleanup (PG default: 200)
#PG_MAINTENANCE_WORK_MEM=256MB      # 4x more memory for vacuum (PG default: 64MB)

# Minimum dead tuples before a table counts toward autovacuum health status.
# Tables below this threshold are shown but don't trigger warnings. (default: 1000)
#AUTOVACUUM_MIN_DEAD_TUPLES=1000

# =============================================================================
# Data Retention (optional — unset means keep forever, like stock TAK Server)
# =============================================================================
# Days to keep CoT messages (position reports, sensor data)
#COT_RETENTION_DAYS=30

# Days to keep geochat messages
#GEOCHAT_RETENTION_DAYS=90

# Override the retention schedule (Quartz cron syntax)
# Auto-defaults to daily 3 AM when any retention days are set
#RETENTION_CRON=0 0 3 * * ?
