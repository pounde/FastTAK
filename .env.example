###############################################################################
# FastTAK Environment Configuration
#
# First run:
#   ./setup.sh <takserver-docker-X.X.zip>
#   vim .env                # set FQDN, review passwords
#   ./start.sh              # or: docker compose up -d --build
###############################################################################

# =============================================================================
# User Settings — review and set these before starting
# =============================================================================

# Server address — IP, hostname, or FQDN that clients use to reach this server.
# Examples:
#   192.168.1.50              (field deployment, air-gapped)
#   myserver.tail1234.ts.net  (Tailscale hostname)
#   tak.example.com           (public FQDN with DNS)
SERVER_ADDRESS=tak.example.com

# Deployment mode:
#   direct    — port-based routing through Caddy, self-signed TLS. No DNS needed.
#               Each service gets its own port (e.g., https://192.168.1.50:8446).
#   subdomain — subdomain-based routing through Caddy, Let's Encrypt TLS.
#               Requires public DNS with wildcard or per-service records.
#               Each service gets a subdomain (e.g., https://portal.tak.example.com).
DEPLOY_MODE=subdomain

# Admin password for the 'webadmin' user. This account is used to log in to:
#   - TAK Server web admin at https://<FQDN>:8446
#   - TAK Portal (when PORTAL_AUTH_ENABLED=true)
# Both authenticate against LDAP — same user, same password.
# DEFAULT VALUE — change for production. Leave empty to skip webadmin user creation.
TAK_WEBADMIN_PASSWORD=FastTAK-Admin-1!

# =============================================================================
# Version Pins — change to upgrade services
# =============================================================================

TAK_VERSION=5.6
LLDAP_VERSION=v0.6.1
MEDIAMTX_VERSION=1.15.5
NODERED_VERSION=4.1
TAK_PORTAL_VERSION=1.2.53

# =============================================================================
# Port Assignments (direct mode only)
# =============================================================================
# Which host ports Caddy listens on for each service in direct mode.
# Ignored in subdomain mode (everything is on 443 via subdomains).
# Portal is always on 443 (Caddy's default HTTPS port).
NODERED_PORT=1880
MONITOR_PORT=8180
TAKSERVER_ADMIN_PORT=8446
MEDIAMTX_PORT=8888

# =============================================================================
# Subdomains (subdomain mode only)
# =============================================================================
# Ignored in direct mode (services are accessed by port instead).

TAKSERVER_SUBDOMAIN=takserver
MEDIAMTX_SUBDOMAIN=stream
TAKPORTAL_SUBDOMAIN=portal
NODERED_SUBDOMAIN=nodered
MONITOR_SUBDOMAIN=monitor

# =============================================================================
# Internal Secrets — generated by setup.sh, used for container-to-container
# communication. Users do not interact with these directly.
# If not using setup.sh, generate with the noted commands.
# =============================================================================

# TAK database password (martiuser PostgreSQL role)
# Generate with:  openssl rand -hex 16
TAK_DB_PASSWORD=

# App database password (shared PostgreSQL for LLDAP + Node-RED)
# Generate with:  openssl rand -hex 16
APP_DB_PASSWORD=

# LDAP bind password (service account for LDAP directory)
# Generate with:  openssl rand -hex 16
LDAP_BIND_PASSWORD=

# =============================================================================
# Optional Settings
# =============================================================================

# LDAP base DN (default: DC=takldap)
#LDAP_BASE_DN=DC=takldap

# PostgreSQL connection URI — only set this if you are NOT using Docker Compose
# and need to connect to an external database. Leave unset for Docker Compose deployments.
# Format: postgresql://user:password@host:port/dbname
#TAK_DB_URL=postgresql://martiuser:mypassword@db-host:5432/cot

# SMTP relay for email notifications and password reset
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=noreply@example.com

# Email alerts — send health alerts to this address
#ALERT_EMAIL=ops@example.com

# SMS alerts
#SMS_PROVIDER=twilio   # "twilio" or "brevo"
#SMS_API_KEY=           # Twilio: "account_sid:auth_token" / Brevo: API key
#SMS_FROM=+15551234567
#SMS_TO=+15559876543    # Comma-separated

# =============================================================================
# User Management
# =============================================================================

# Prefixes to hide from user lists (service accounts)
USERS_HIDDEN_PREFIXES=adm_,svc_,ma-

# How often to check for expired temporary users (seconds)
USER_EXPIRY_CHECK_INTERVAL=60

# Enrollment token validity (minutes). How long the QR code / enrollment link
# stays active after generation.
ENROLLMENT_TOKEN_TTL_MINUTES=15

# Consume enrollment token on first use. Currently false because TAK Server
# binds twice during enrollment (auth + group lookup). TTL is the security
# boundary. Set to true only if TAK Server changes this behavior.
ENROLLMENT_TOKEN_ONE_TIME=false

# TAK Server enrollment port (used for generating enrollment URLs)
TAK_ENROLLMENT_PORT=8446

# =============================================================================
# PostgreSQL Autovacuum Tuning
# =============================================================================
# FastTAK ships tuned autovacuum defaults for the high-write CoT workload.
# These values are applied automatically by tak-database/start.sh. Override
# here to adjust. Set to PostgreSQL defaults (0.2, 200, 64MB) to disable tuning.
# See the FastTAK documentation for database vacuuming details.
PG_AUTOVACUUM_SCALE_FACTOR=0.05 # trigger at 5% dead rows (PG default: 0.2)
PG_AUTOVACUUM_COST_LIMIT=1000   # 5x faster cleanup (PG default: 200)
PG_MAINTENANCE_WORK_MEM=256MB   # 4x more memory for vacuum (PG default: 64MB)

# Minimum dead tuples before a table affects autovacuum health status.
# Prevents false alerts from tiny config tables (e.g., a table with 4 dead rows
# showing 66% dead ratio on a fresh stack). Tables below this count are still
# reported but do not trigger warning/critical status.
AUTOVACUUM_MIN_DEAD_TUPLES=1000

# =============================================================================
# Data Retention
# =============================================================================
# TAK Server keeps all data forever by default. Set retention periods to
# automatically delete old data. When any retention day value is set,
# the retention service schedule auto-defaults to daily at 3 AM.
# Leave unset to keep all data indefinitely (stock TAK Server behavior).
# See the FastTAK documentation for data retention details.

# Days to keep CoT messages (position reports, sensor data).
# Set to enable automatic cleanup. Unset = keep forever.
#COT_RETENTION_DAYS=30

# Days to keep geochat messages. Unset = keep forever.
#GEOCHAT_RETENTION_DAYS=90

# Override the retention schedule (Quartz cron syntax).
# Only needed if you want a different time than the default daily 3 AM.
#RETENTION_CRON=0 0 3 * * ?

# =============================================================================
# Monitoring Threshold Overrides (optional)
# =============================================================================
# Override monitoring thresholds defined in monitor/config/thresholds.yml.
# Uses the FASTAK_MON_ prefix with __ separators for nested keys.
# See the FastTAK configuration documentation for override details.

# Alert cooldown (seconds). After sending an alert for a service, suppress
# repeat alerts for that service until this period elapses.
#FASTAK_MON_ALERT_COOLDOWN=300

# Examples:
#FASTAK_MON_DATABASE__INTERVAL=120                    # poll database every 2 min
#FASTAK_MON_DISK__THRESHOLDS__PERCENT__WARNING=85     # disk warning at 85%
#FASTAK_MON_CERTS__THRESHOLDS__DAYS_LEFT__WARNING=60  # cert warning at 60 days
#FASTAK_MON_CONFIG__ALERT_MIN_LEVEL=warning           # only email on config drift if warning+
